FROM debian:trixie-slim

# sway (wlroots compositor) + wayvnc + noVNC + Electron deps + agent-driving tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    sway \
    wayvnc \
    websockify \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libgbm1 \
    libasound2t64 \
    libpango-1.0-0 \
    libcairo2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxshmfence1 \
    libglib2.0-0 \
    libdbus-1-3 \
    libgtk-3-0t64 \
    fonts-dejavu-core \
    fonts-liberation \
    unzip \
    ca-certificates \
    curl \
    seatd \
    rsync \
    sqlite3 \
    grim \
    jq \
    wf-recorder \
    wtype \
    wlrctl \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Download noVNC
RUN curl -fsSL https://github.com/novnc/noVNC/archive/refs/heads/master.tar.gz | \
    tar xz -C /opt && mv /opt/noVNC-master /opt/novnc

# Pre-download Electron + tsgo (cached)
WORKDIR /setup-cache
COPY scripts/setup scripts/setup
COPY scripts/lib scripts/lib
COPY scripts/vendor-versions.json scripts/vendor-versions.json
RUN ELECTRON_INSTALL_PLATFORM=linux ELECTRON_INSTALL_ARCH=arm64 node scripts/setup

WORKDIR /app

# Tiny Host-rewriting proxy so the Electron CDP (which rejects Host headers
# other than localhost:9223) can be reached via published Docker ports.
RUN cat > /cdp-proxy.mjs << 'PROXY'
import http from 'node:http';
import net from 'node:net';

const LISTEN = Number(process.env.CDP_PROXY_PORT || 9224);
const TARGET_HOST = '127.0.0.1';
const TARGET_PORT = Number(process.env.CDP_PORT || 9223);
const HOST_HEADER = `localhost:${TARGET_PORT}`;

const server = http.createServer((req, res) => {
  const headers = { ...req.headers, host: HOST_HEADER };
  const upstream = http.request({
    host: TARGET_HOST, port: TARGET_PORT, method: req.method, path: req.url, headers,
  }, (ures) => {
    // Rewrite any localhost:9223 references in JSON to the proxy's host:port
    // so tools that follow the printed ws URLs connect back through the proxy.
    const proxyHost = (req.headers.host || `localhost:${LISTEN}`);
    let buf = [];
    ures.on('data', (c) => buf.push(c));
    ures.on('end', () => {
      let body = Buffer.concat(buf);
      const ct = ures.headers['content-type'] || '';
      if (ct.includes('application/json') || ct.includes('text/')) {
        body = Buffer.from(body.toString('utf-8').replaceAll(HOST_HEADER, proxyHost));
      }
      const outHeaders = { ...ures.headers };
      delete outHeaders['content-length'];
      res.writeHead(ures.statusCode || 200, outHeaders);
      res.end(body);
    });
  });
  upstream.on('error', (e) => { res.writeHead(502); res.end(String(e)); });
  req.pipe(upstream);
});

server.on('upgrade', (req, socket, head) => {
  const headers = { ...req.headers, host: HOST_HEADER };
  const upstream = net.connect(TARGET_PORT, TARGET_HOST, () => {
    const reqLines = [`${req.method} ${req.url} HTTP/${req.httpVersion}`];
    for (const [k, v] of Object.entries(headers)) reqLines.push(`${k}: ${v}`);
    upstream.write(reqLines.join('\r\n') + '\r\n\r\n');
    if (head && head.length) upstream.write(head);
    upstream.pipe(socket);
    socket.pipe(upstream);
  });
  upstream.on('error', () => socket.destroy());
  socket.on('error', () => upstream.destroy());
});

server.listen(LISTEN, '0.0.0.0', () => {
  console.log(`[cdp-proxy] 0.0.0.0:${LISTEN} -> ${TARGET_HOST}:${TARGET_PORT}`);
});
PROXY

# CDP evaluate helper. Usage:
#   node /cdp-eval.mjs [--target <url-fragment>] '<js-expression>'
#
# Runs the expression in the chosen target's page (default: app://index.html).
# Prints the evaluated value as JSON on stdout; prints errors to stderr and
# exits non-zero. Uses awaitPromise+returnByValue so async IPC calls like
# window.ipc.tabs.openTab(...) work transparently.
RUN cat > /cdp-eval.mjs << 'EVAL'
import http from 'node:http';

const args = process.argv.slice(2);
let targetFrag = 'app://';
for (let i = 0; i < args.length; i++) {
  if (args[i] === '--target' && args[i + 1]) { targetFrag = args[i + 1]; args.splice(i, 2); i--; }
}
const expression = args.join(' ');
if (!expression) {
  console.error('Usage: cdp-eval.mjs [--target <url-fragment>] <expression>');
  process.exit(2);
}

const CDP_PORT = Number(process.env.CDP_PORT || 9223);

function httpGet(path) {
  return new Promise((resolve, reject) => {
    const req = http.get({ host: '127.0.0.1', port: CDP_PORT, path, headers: { Host: `localhost:${CDP_PORT}` } }, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => resolve({ status: res.statusCode, body: Buffer.concat(chunks).toString('utf-8') }));
    });
    req.on('error', reject);
  });
}

async function waitForTarget(timeoutMs) {
  const start = Date.now();
  while (Date.now() - start < timeoutMs) {
    try {
      const { status, body } = await httpGet('/json');
      if (status === 200) {
        const list = JSON.parse(body);
        const match = list.find((t) => t.type === 'page' && t.url.includes(targetFrag));
        if (match) return match;
      }
    } catch {}
    await new Promise((r) => setTimeout(r, 200));
  }
  throw new Error(`No CDP page target matched "${targetFrag}" within ${timeoutMs}ms`);
}

const target = await waitForTarget(15000);

await new Promise((resolve, reject) => {
  const ws = new WebSocket(target.webSocketDebuggerUrl);
  let id = 0;
  const pending = new Map();
  const send = (method, params = {}) => new Promise((res, rej) => {
    const mid = ++id;
    pending.set(mid, { resolve: res, reject: rej });
    ws.send(JSON.stringify({ id: mid, method, params }));
  });
  ws.onmessage = (ev) => {
    const msg = JSON.parse(ev.data);
    if (!msg.id || !pending.has(msg.id)) return;
    const { resolve: r, reject: j } = pending.get(msg.id);
    pending.delete(msg.id);
    if (msg.error) j(new Error(msg.error.message));
    else r(msg.result);
  };
  ws.onerror = (e) => reject(new Error(`WebSocket error: ${e.message || 'connection failed'}`));
  ws.onopen = async () => {
    try {
      await send('Runtime.enable');
      // Try parsing as a single expression first (so the return value is
      // the expression value). Fall back to treating the code as a
      // statement body if that syntax errors. This lets callers pass
      // either "await window.ipc.tabs.getTabState()" or a multi-statement
      // block ending in a `return`.
      const codeLiteral = JSON.stringify(expression);
      const wrapped = `(async () => {
        const __code = ${codeLiteral};
        const __AsyncFn = (async function(){}).constructor;
        let __fn;
        try {
          __fn = new __AsyncFn('return (\\n' + __code + '\\n);');
        } catch (__err) {
          if (!(__err instanceof SyntaxError)) throw __err;
          __fn = new __AsyncFn(__code);
        }
        const __result = await __fn();
        return __result === undefined ? null : __result;
      })()`;
      const result = await send('Runtime.evaluate', {
        expression: wrapped,
        awaitPromise: true,
        returnByValue: true,
        userGesture: true,
      });
      if (result.exceptionDetails) {
        const text = result.exceptionDetails.exception?.description || result.exceptionDetails.text;
        ws.close();
        // Surface the target + original expression so the agent can see
        // *what* actually ran, not just *how* it failed.
        const detail = [
          `[cdp-eval] target: ${target.url}`,
          `[cdp-eval] expression: ${expression}`,
          text,
        ].join('\n');
        reject(new Error(detail));
        return;
      }
      const value = result.result?.value;
      process.stdout.write(typeof value === 'string' ? value : JSON.stringify(value));
      process.stdout.write('\n');
      ws.close();
      resolve();
    } catch (err) {
      ws.close();
      reject(err);
    }
  };
});
EVAL

# Stream Runtime.consoleAPICalled from the main renderer's CDP target to
# stdout. Usage: node /cdp-logs.mjs [--target <url-fragment>]
# (default target: app://index.html).
RUN cat > /cdp-logs.mjs << 'LOGS'
import http from 'node:http';

const args = process.argv.slice(2);
let targetFrag = 'app://';
for (let i = 0; i < args.length; i++) {
  if (args[i] === '--target' && args[i + 1]) { targetFrag = args[i + 1]; args.splice(i, 2); i--; }
}

const CDP_PORT = Number(process.env.CDP_PORT || 9223);

function httpGet(path) {
  return new Promise((resolve, reject) => {
    const req = http.get({ host: '127.0.0.1', port: CDP_PORT, path, headers: { Host: `localhost:${CDP_PORT}` } }, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => resolve({ status: res.statusCode, body: Buffer.concat(chunks).toString('utf-8') }));
    });
    req.on('error', reject);
  });
}

async function waitForTarget() {
  for (;;) {
    try {
      const { status, body } = await httpGet('/json');
      if (status === 200) {
        const list = JSON.parse(body);
        const match = list.find((t) => t.type === 'page' && t.url.includes(targetFrag));
        if (match) return match;
      }
    } catch {}
    await new Promise((r) => setTimeout(r, 500));
  }
}

function formatArg(p) {
  if (p.value !== undefined) return typeof p.value === 'string' ? p.value : JSON.stringify(p.value);
  if (p.description) return p.description;
  if (p.preview) return JSON.stringify(p.preview);
  return p.type;
}

async function attach(target) {
  const ws = new WebSocket(target.webSocketDebuggerUrl);
  let id = 0;
  const send = (method, params = {}) => new Promise((res, rej) => {
    const mid = ++id;
    const onMsg = (ev) => {
      const msg = JSON.parse(ev.data);
      if (msg.id !== mid) return;
      ws.removeEventListener('message', onMsg);
      if (msg.error) rej(new Error(msg.error.message));
      else res(msg.result);
    };
    ws.addEventListener('message', onMsg);
    ws.send(JSON.stringify({ id: mid, method, params }));
  });
  await new Promise((r) => ws.addEventListener('open', r, { once: true }));
  ws.addEventListener('message', (ev) => {
    const msg = JSON.parse(ev.data);
    if (msg.method === 'Runtime.consoleAPICalled') {
      const level = msg.params.type.padEnd(5);
      const args = msg.params.args.map(formatArg).join(' ');
      console.log(`[${level}] ${args}`);
    } else if (msg.method === 'Runtime.exceptionThrown') {
      const e = msg.params.exceptionDetails;
      console.log(`[EXC  ] ${e.exception?.description || e.text}`);
    }
  });
  ws.addEventListener('close', () => process.exit(0));
  await send('Runtime.enable');
  console.error(`[cdp-logs] attached to ${target.url}`);
}

const t = await waitForTarget();
await attach(t);
// Keep alive until the socket closes.
setInterval(() => {}, 1 << 30);
LOGS

# Entrypoint: sway + wayvnc + noVNC + app rebuild loop
# Source is mounted at /src at runtime. Built into /app.
RUN cat > /entrypoint.sh << 'ENTRY' \
&& chmod +x /entrypoint.sh
#!/bin/bash
set -e
export AGENT_PATH="${AGENT_PATH:-/tmp/preview-agent}"
mkdir -p "$AGENT_PATH"
VNC_PORT="${VNC_PORT:-5900}"; WEB_PORT="${WEB_PORT:-6080}"
# CDP is always bound to 127.0.0.1:9223 inside the container. A tiny
# Host-rewriting proxy on 0.0.0.0:CDP_PROXY_PORT is what actually gets
# published to the host — Chromium otherwise rejects the "Host: localhost:<host-port>"
# header that Docker port-forwarding produces.
CDP_PORT="${CDP_PORT:-9223}"
CDP_PROXY_PORT="${CDP_PROXY_PORT:-9224}"
export XDG_RUNTIME_DIR="/tmp/preview-xdg"
mkdir -p "$XDG_RUNTIME_DIR" && chmod 700 "$XDG_RUNTIME_DIR"
if [ ! -d /src/src ]; then
  echo "[preview] Error: mount source with -v /path/to/worktree:/src:ro"
  exit 1
fi
echo '{}' > /tmp/preview-config.json
seatd -g root &
sleep 0.3
export LIBSEAT_BACKEND=seatd
export WLR_BACKENDS=headless WLR_HEADLESS_OUTPUTS=1 WLR_NO_HARDWARE_CURSORS=1 XDG_CONFIG_HOME=/tmp
mkdir -p /tmp/sway
cat > /tmp/sway/config << 'SWAY'
default_border none
default_floating_border none
font pango:monospace 1
bar { mode invisible }
SWAY
sway &
SWAY_PID=$!
for i in $(seq 1 30); do
  SOCK=$(ls "$XDG_RUNTIME_DIR"/wayland-* 2>/dev/null | grep -v lock | head -1)
  [ -n "$SOCK" ] && break
  sleep 0.5
done
export WAYLAND_DISPLAY=$(basename "$SOCK")
echo "[preview] Sway ready: $WAYLAND_DISPLAY"
(
  while kill -0 $SWAY_PID 2>/dev/null; do
    echo "[preview] Building app from /src..."
    # -c forces checksum comparison — macOS bind-mount mtimes can come back
    # with coarser precision than the /app side, so default size+mtime can
    # falsely skip real edits.
    rsync -ac --delete \
      --exclude='vendor/' --exclude='dist/' --exclude='node_modules/' \
      --exclude='.git/' --exclude='tests/' --exclude='.claude/' \
      /src/ /app/
    ln -sfn /setup-cache/vendor /app/vendor
    node /app/scripts/build
    echo "[preview] Starting Electron..."
    CDP_ARGS=""
    if [ -n "$CDP_PORT" ]; then
      CDP_ARGS="--remote-debugging-port=$CDP_PORT"
    fi
    # Keep the main renderer foregrounded: wayvnc doesn't expose visibility
    # the way a real OS window manager does, so Chromium otherwise marks the
    # document as hidden, which throttles requestAnimationFrame to zero and
    # breaks any renderer code that depends on it (ResizeObserver scheduling,
    # our tab-view bounds sync, etc). The three disable-* flags match what
    # Playwright/puppeteer use for the same reason.
    AGENTWFY_CONFIG="/tmp/preview-config.json" \
    AGENTWFY_APP_ID="AgentWFY-preview" \
    AGENTWFY_PREVIEW_CURSOR=1 \
    node /app/scripts/start "--agent-path=${AGENT_PATH}" \
      --ozone-platform=wayland --no-sandbox --disable-gpu --disable-dev-shm-usage \
      --disable-renderer-backgrounding --disable-backgrounding-occluded-windows \
      --disable-background-timer-throttling $CDP_ARGS || true
    echo "[preview] App exited. Rebuilding..."
    sleep 1
  done
) &
sleep 10
(
  while kill -0 $SWAY_PID 2>/dev/null; do
    wayvnc --output=HEADLESS-1 --render-cursor --max-fps=60 0.0.0.0 "$VNC_PORT" 2>/dev/null || true
    sleep 2
  done
) &
sleep 2
websockify --web=/opt/novnc "$WEB_PORT" "localhost:$VNC_PORT" &

# Force the Electron main window to fill the compositor output.
# Chromium's Wayland client reports its own natural geometry (~830x641)
# and ignores the size in sway's initial xdg_toplevel.configure — so a
# plain `for_window ... fullscreen enable` rule (applied at window
# creation) leaves the surface small in the top-left corner with the
# rest of the 1280x720 output black. Issuing `fullscreen` over IPC
# *after* the surface is mapped produces a fresh configure event that
# Chromium does honor. This watcher polls for the electron toplevel and
# re-applies fullscreen whenever a new con_id appears, which also
# covers the rebuild-loop restart case (old window goes away, new one
# gets resized on the next poll). Toggle off/on because sway treats an
# "enable" on an already-fullscreen window as a no-op and wouldn't emit
# a new configure.
(
  export SWAYSOCK=$(ls "$XDG_RUNTIME_DIR"/sway-ipc.*.sock 2>/dev/null | head -1)
  PREV_ID=""
  while kill -0 $SWAY_PID 2>/dev/null; do
    ID=$(swaymsg -t get_tree 2>/dev/null | jq -r '[.. | objects | select(.app_id? == "electron")] | first | .id // empty')
    if [ -n "$ID" ] && [ "$ID" != "$PREV_ID" ]; then
      sleep 0.5
      swaymsg "[con_id=$ID] fullscreen disable" >/dev/null 2>&1 || true
      swaymsg "[con_id=$ID] fullscreen enable" >/dev/null 2>&1 || true
      PREV_ID=$ID
    elif [ -z "$ID" ]; then
      PREV_ID=""
    fi
    sleep 0.5
  done
) &
if [ -n "$CDP_PORT" ]; then
  ( while true; do CDP_PORT="$CDP_PORT" CDP_PROXY_PORT="$CDP_PROXY_PORT" node /cdp-proxy.mjs || true; sleep 2; done ) &
fi
echo ""
echo "  VNC:   http://localhost:$WEB_PORT/vnc.html?autoconnect=true&resize=scale&quality=9&compression=0"
if [ -n "$CDP_PORT" ]; then
  echo "  CDP:   http://localhost:$CDP_PROXY_PORT/json  (via Host-rewriting proxy)"
fi
echo ""
wait $SWAY_PID 2>/dev/null
ENTRY

EXPOSE 6080 9224
ENTRYPOINT ["/entrypoint.sh"]
