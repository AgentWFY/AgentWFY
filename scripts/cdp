#!/usr/bin/env node
// =============================================================================
// cdp — CDP-based test runner for the Electron app
//
// Commands:
//   start [--visible]        Start isolated test instance (headless by default)
//   stop                     Stop app and clean up test data
//   restart                  Restart app and wait until ready
//   run <script-or-file>     Execute a JS test script with the full API in scope
// =============================================================================

import { writeFileSync, readFileSync, existsSync, mkdtempSync, mkdirSync, rmSync, unlinkSync } from 'node:fs';
import { dirname, join, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import { tmpdir, homedir } from 'node:os';
import { randomBytes } from 'node:crypto';
import { spawn } from 'node:child_process';
import { createServer } from 'node:net';

function getCdpPort() {
  return process.env.CDP_PORT || '9223';
}
function getCdpBase() {
  return `http://localhost:${getCdpPort()}`;
}

// ── CDP Protocol Helpers ────────────────────────────────────────────────────

async function cdpFetch(path) {
  const res = await fetch(`${getCdpBase()}${path}`);
  if (!res.ok) throw new Error(`CDP HTTP ${res.status}: ${await res.text()}`);
  return res.json();
}

async function getBrowserWsUrl() {
  const version = await cdpFetch('/json/version');
  return version.webSocketDebuggerUrl;
}

async function getTargets() {
  let httpTargets;
  try {
    httpTargets = await cdpFetch('/json/list');
  } catch {
    httpTargets = [];
  }

  try {
    const browserWsUrl = await getBrowserWsUrl();
    const browser = await connectWebSocket(browserWsUrl);
    const { targetInfos } = await browser.send('Target.getTargets');
    browser.close();

    const httpIds = new Set(httpTargets.map(t => t.id));
    const port = getCdpPort();

    for (const info of targetInfos) {
      if (httpIds.has(info.targetId)) continue;
      if (info.type !== 'page') continue;

      httpTargets.push({
        id: info.targetId,
        type: info.type,
        title: info.title,
        url: info.url,
        webSocketDebuggerUrl: `ws://localhost:${port}/devtools/page/${info.targetId}`,
        _needsSession: true,
      });
    }
  } catch {
    // Fall back to HTTP list only
  }

  return httpTargets;
}

async function getMainTarget() {
  const targets = await getTargets();
  return targets.find(t => t.url.includes('app://')) || targets[0];
}

function connectWebSocket(wsUrl) {
  return new Promise((resolve, reject) => {
    const ws = new globalThis.WebSocket(wsUrl);
    let id = 0;
    const pending = new Map();

    ws.onopen = () => resolve({
      send(method, params = {}) {
        return new Promise((res, rej) => {
          const msgId = ++id;
          pending.set(msgId, { resolve: res, reject: rej });
          ws.send(JSON.stringify({ id: msgId, method, params }));
        });
      },
      close() { ws.close(); ws.onmessage = null; ws.onerror = null; },
      ws,
    });

    ws.onmessage = (event) => {
      const msg = JSON.parse(event.data);
      if (msg.id && pending.has(msg.id)) {
        const { resolve, reject } = pending.get(msg.id);
        pending.delete(msg.id);
        if (msg.error) reject(new Error(msg.error.message));
        else resolve(msg.result);
      }
    };

    ws.onerror = (err) => reject(new Error(`WebSocket error: ${err.message || 'connection failed'}`));
    setTimeout(() => reject(new Error('WebSocket timeout')), 5000);
  });
}

// ── Session-based connection (for WebContentsView targets) ────────────────

function connectViaSession(targetId) {
  return new Promise(async (resolve, reject) => {
    let browserWsUrl;
    try {
      browserWsUrl = await getBrowserWsUrl();
    } catch (e) {
      return reject(e);
    }

    const ws = new globalThis.WebSocket(browserWsUrl);
    let id = 0;
    const pending = new Map();
    let sessionId = null;

    ws.onmessage = (event) => {
      const msg = JSON.parse(event.data);
      if (!msg.id || !pending.has(msg.id)) return;
      if (sessionId && msg.sessionId && msg.sessionId !== sessionId) return;
      const { resolve: res, reject: rej } = pending.get(msg.id);
      pending.delete(msg.id);
      if (msg.error) rej(new Error(msg.error.message));
      else res(msg.result);
    };

    ws.onerror = (err) => reject(new Error(`Session WebSocket error: ${err.message || 'connection failed'}`));
    const timer = setTimeout(() => reject(new Error('Session connection timeout')), 5000);

    ws.onopen = async () => {
      clearTimeout(timer);
      const sendMsg = (method, params = {}) => {
        return new Promise((res, rej) => {
          const msgId = ++id;
          pending.set(msgId, { resolve: res, reject: rej });
          const msg = { id: msgId, method, params };
          if (sessionId) msg.sessionId = sessionId;
          ws.send(JSON.stringify(msg));
        });
      };

      try {
        const result = await sendMsg('Target.attachToTarget', { targetId, flatten: true });
        sessionId = result.sessionId;

        resolve({
          send(method, params = {}) {
            return new Promise((res, rej) => {
              const msgId = ++id;
              pending.set(msgId, { resolve: res, reject: rej });
              ws.send(JSON.stringify({ id: msgId, method, params, sessionId }));
            });
          },
          close() {
            ws.close();
            ws.onmessage = null;
            ws.onerror = null;
          },
          ws,
        });
      } catch (err) {
        ws.close();
        reject(err);
      }
    };
  });
}

async function connectTo(targetId) {
  let target;
  if (targetId) {
    const targets = await getTargets();
    target = targets.find(t => t.id.startsWith(targetId));
    if (!target) throw new Error(`Target not found: ${targetId}`);
  } else {
    target = await getMainTarget();
    if (!target) throw new Error('No target found');
  }

  if (target.webSocketDebuggerUrl) {
    try {
      return await connectWebSocket(target.webSocketDebuggerUrl);
    } catch {
      // Direct WebSocket failed — fall through to session
    }
  }

  return connectViaSession(target.id);
}

// ── Deep Query (Shadow DOM traversal) ─────────────────────────────────────

const DEEP_QUERY_FN = `
function deepQuery(selector) {
  let el = document.querySelector(selector);
  if (el) return el;
  const walk = (root) => {
    for (const child of root.querySelectorAll('*')) {
      if (child.shadowRoot) {
        const found = child.shadowRoot.querySelector(selector);
        if (found) return found;
        const deeper = walk(child.shadowRoot);
        if (deeper) return deeper;
      }
    }
    return null;
  };
  return walk(document);
}`;

// ── Input Dispatch Helpers ────────────────────────────────────────────────

async function dispatchClick(cdp, x, y, button = 'left', clickCount = 1) {
  await cdp.send('Input.dispatchMouseEvent', {
    type: 'mousePressed', x, y, button, clickCount,
  });
  await cdp.send('Input.dispatchMouseEvent', {
    type: 'mouseReleased', x, y, button, clickCount,
  });
}

const MODIFIERS = { Alt: 1, Control: 2, Meta: 4, Shift: 8 };

const KEY_MAP = {
  enter:     { key: 'Enter',     code: 'Enter',       keyCode: 13 },
  tab:       { key: 'Tab',       code: 'Tab',         keyCode: 9 },
  escape:    { key: 'Escape',    code: 'Escape',      keyCode: 27 },
  backspace: { key: 'Backspace', code: 'Backspace',   keyCode: 8 },
  delete:    { key: 'Delete',    code: 'Delete',      keyCode: 46 },
  arrowup:   { key: 'ArrowUp',   code: 'ArrowUp',     keyCode: 38 },
  arrowdown: { key: 'ArrowDown', code: 'ArrowDown',   keyCode: 40 },
  arrowleft: { key: 'ArrowLeft', code: 'ArrowLeft',   keyCode: 37 },
  arrowright:{ key: 'ArrowRight',code: 'ArrowRight',  keyCode: 39 },
  space:     { key: ' ',         code: 'Space',        keyCode: 32 },
  home:      { key: 'Home',      code: 'Home',         keyCode: 36 },
  end:       { key: 'End',       code: 'End',          keyCode: 35 },
  pageup:    { key: 'PageUp',    code: 'PageUp',       keyCode: 33 },
  pagedown:  { key: 'PageDown',  code: 'PageDown',     keyCode: 34 },
};

function resolveKey(name) {
  const lower = name.toLowerCase();
  if (KEY_MAP[lower]) return KEY_MAP[lower];
  if (name.length === 1) {
    const upper = name.toUpperCase();
    return { key: name, code: `Key${upper}`, keyCode: upper.charCodeAt(0) };
  }
  return { key: name, code: name, keyCode: 0 };
}

async function dispatchKey(cdp, keyName, modifiers = 0) {
  const k = resolveKey(keyName);
  const downType = modifiers ? 'rawKeyDown' : 'keyDown';
  await cdp.send('Input.dispatchKeyEvent', {
    type: downType, key: k.key, code: k.code,
    windowsVirtualKeyCode: k.keyCode, nativeVirtualKeyCode: k.keyCode,
    modifiers,
  });
  if (k.key.length === 1 && modifiers === 0) {
    await cdp.send('Input.dispatchKeyEvent', {
      type: 'char', text: k.key, key: k.key,
      windowsVirtualKeyCode: k.keyCode, nativeVirtualKeyCode: k.keyCode,
      modifiers,
    });
  }
  await cdp.send('Input.dispatchKeyEvent', {
    type: 'keyUp', key: k.key, code: k.code,
    windowsVirtualKeyCode: k.keyCode, nativeVirtualKeyCode: k.keyCode,
    modifiers,
  });
}

function parseCombo(combo) {
  const parts = combo.split('+');
  const keyName = parts.pop();
  let modBits = 0;
  for (const part of parts) {
    const mod = part.charAt(0).toUpperCase() + part.slice(1).toLowerCase();
    if (MODIFIERS[mod]) modBits |= MODIFIERS[mod];
  }
  return { keyName, modBits };
}

async function typeText(cdp, text) {
  for (const ch of text) {
    await dispatchKey(cdp, ch);
  }
}

// ── Element helpers (used by API functions) ───────────────────────────────

async function evalInTarget(cdp, js) {
  await cdp.send('Runtime.enable');
  const result = await cdp.send('Runtime.evaluate', {
    expression: js,
    returnByValue: true,
    awaitPromise: true,
  });
  if (result.exceptionDetails) {
    const text = result.exceptionDetails.text;
    const desc = result.exceptionDetails.exception?.description || '';
    throw new Error(desc || text);
  }
  return result.result.value;
}

async function getElementRect(cdp, selector) {
  const val = await evalInTarget(cdp, `(() => {
    ${DEEP_QUERY_FN}
    const el = deepQuery(${JSON.stringify(selector)});
    if (!el) return { error: 'not found' };
    const rect = el.getBoundingClientRect();
    if (rect.width === 0 && rect.height === 0) return { error: 'zero size (hidden?)' };
    return { x: rect.x, y: rect.y, width: rect.width, height: rect.height };
  })()`);
  if (val.error) throw new Error(`Element "${selector}": ${val.error}`);
  return val;
}

// ── Lifecycle ─────────────────────────────────────────────────────────────

function sessionMetaPath(port) {
  return join(tmpdir(), `agentwfy-cdp-${port}.json`);
}

function findFreePort() {
  return new Promise((resolve, reject) => {
    const srv = createServer();
    srv.listen(0, '127.0.0.1', () => {
      const port = srv.address().port;
      srv.close(() => resolve(port));
    });
    srv.on('error', reject);
  });
}

async function cmdWait(timeoutSecs = 30) {
  const timeout = timeoutSecs * 1000;
  const start = Date.now();

  while (Date.now() - start < timeout) {
    try {
      const targets = await cdpFetch('/json/list');
      const main = targets.find(t => t.url.includes('app://'));
      if (main) {
        const cdp = await connectWebSocket(main.webSocketDebuggerUrl);
        await cdp.send('Runtime.enable');
        const result = await cdp.send('Runtime.evaluate', {
          expression: 'typeof window.ipc !== "undefined" && typeof window.ipc.getAgentRoot === "function"',
          returnByValue: true,
        });
        cdp.close();
        if (result.result.value === true) {
          return;
        }
      }
    } catch {}
    await new Promise(r => setTimeout(r, 300));
  }

  throw new Error(`Timed out after ${timeoutSecs}s`);
}

async function cmdStart(args) {
  const visible = args.includes('--visible');
  const port = parseInt(process.env.CDP_PORT, 10) || await findFreePort();
  const appId = `AgentWFY-test-${randomBytes(4).toString('hex')}`;
  const testDir = mkdtempSync(join(tmpdir(), 'agentwfy-test-'));
  const configPath = join(testDir, 'config.json');
  const agentPath = join(testDir, 'agent');

  writeFileSync(configPath, '{}');
  mkdirSync(agentPath);

  const scriptsDir = dirname(fileURLToPath(import.meta.url));
  const startScript = join(scriptsDir, 'start');

  const env = {
    ...process.env,
    CDP_PORT: String(port),
    AGENTWFY_CONFIG: configPath,
    AGENTWFY_APP_ID: appId,
  };
  if (!visible) env.AGENTWFY_HEADLESS = '1';

  const child = spawn(process.execPath, [startScript, `--agent-path=${agentPath}`], {
    stdio: ['ignore', 'inherit', 'inherit'],
    env,
    detached: true,
  });
  child.unref();

  writeFileSync(sessionMetaPath(port), JSON.stringify({ testDir, appId }));

  process.env.CDP_PORT = String(port);
  await cmdWait();

  console.log(`port: ${port}`);
}

async function cmdStop() {
  const port = getCdpPort();
  try {
    const target = await getMainTarget();
    if (target) {
      const cdp = await connectWebSocket(target.webSocketDebuggerUrl);
      await cdp.send('Runtime.enable');
      cdp.send('Runtime.evaluate', {
        expression: 'window.ipc.stop()',
        returnByValue: true,
        awaitPromise: true,
      }).catch(() => {});
      await new Promise(r => setTimeout(r, 500));
    }
  } catch {}

  const metaPath = sessionMetaPath(port);
  try {
    const meta = JSON.parse(readFileSync(metaPath, 'utf-8'));
    if (meta.testDir) rmSync(meta.testDir, { recursive: true, force: true });
    if (meta.appId) {
      const userDataDir = join(homedir(), 'Library', 'Application Support', meta.appId);
      rmSync(userDataDir, { recursive: true, force: true });
    }
    unlinkSync(metaPath);
  } catch {}

  console.log('stopped');
}

async function cmdRestart() {
  try {
    const target = await getMainTarget();
    if (target) {
      const cdp = await connectWebSocket(target.webSocketDebuggerUrl);
      await cdp.send('Runtime.enable');
      cdp.send('Runtime.evaluate', {
        expression: 'window.ipc.restart()',
        returnByValue: true,
        awaitPromise: true,
      }).catch(() => {});
      await new Promise(r => setTimeout(r, 500));
    }
  } catch {}
  await cmdWait();
  console.log('ready');
}

// ── Run Command ───────────────────────────────────────────────────────────

function emit(type, data) {
  console.log(JSON.stringify({ type, ...data }));
}

async function cmdRun(scriptArg) {
  if (!scriptArg) {
    console.error('Usage: ./scripts/cdp run <js-string-or-file>');
    process.exit(1);
  }

  // Determine if arg is a file path or inline JS
  let script;
  const resolved = resolve(scriptArg);
  if (existsSync(resolved) && !scriptArg.includes('(') && !scriptArg.includes('=')) {
    script = readFileSync(resolved, 'utf-8');
  } else {
    script = scriptArg;
  }

  // Connection pool: one connection per target, reused across all API calls
  const connCache = new Map(); // key: targetId or '__main__' → CDP connection

  async function getConn(targetId) {
    const key = targetId || '__main__';
    if (connCache.has(key)) return connCache.get(key);
    const conn = await connectTo(targetId);
    await conn.send('Runtime.enable');
    connCache.set(key, conn);
    return conn;
  }

  function closeAll() {
    for (const conn of connCache.values()) {
      try { conn.close(); } catch {}
    }
    connCache.clear();
  }

  // Build the API
  const api = {
    // ── Targets ──────────────────────────────────────────────────

    async targets() {
      const t = await getTargets();
      return t.map(({ id, type, title, url }) => ({ id: id.slice(0, 8), fullId: id, type, title, url }));
    },

    async mainTarget() {
      const t = await getMainTarget();
      if (!t) throw new Error('No main target found');
      return { id: t.id.slice(0, 8), fullId: t.id, type: t.type, title: t.title, url: t.url };
    },

    // ── Eval ─────────────────────────────────────────────────────

    async eval(js) {
      const conn = await getConn();
      return evalInTarget(conn, js);
    },

    async evalTarget(targetId, js) {
      const conn = await getConn(targetId);
      return evalInTarget(conn, js);
    },

    // ── Click ────────────────────────────────────────────────────

    async click(selector) {
      const conn = await getConn();
      const rect = await getElementRect(conn, selector);
      const x = Math.round(rect.x + rect.width / 2);
      const y = Math.round(rect.y + rect.height / 2);
      await dispatchClick(conn, x, y);
      emit('action', { action: 'click', selector, x, y });
    },

    async clickTarget(targetId, selector) {
      const conn = await getConn(targetId);
      const rect = await getElementRect(conn, selector);
      const x = Math.round(rect.x + rect.width / 2);
      const y = Math.round(rect.y + rect.height / 2);
      await dispatchClick(conn, x, y);
      emit('action', { action: 'click', target: targetId, selector, x, y });
    },

    async clickAt(x, y) {
      const conn = await getConn();
      await dispatchClick(conn, Math.round(x), Math.round(y));
      emit('action', { action: 'clickAt', x, y });
    },

    // ── Type ─────────────────────────────────────────────────────

    async type(text) {
      const conn = await getConn();
      await typeText(conn, text);
      emit('action', { action: 'type', text });
    },

    async typeTarget(targetId, text) {
      const conn = await getConn(targetId);
      await typeText(conn, text);
      emit('action', { action: 'type', target: targetId, text });
    },

    // ── Press ────────────────────────────────────────────────────

    async press(combo) {
      const conn = await getConn();
      const { keyName, modBits } = parseCombo(combo);
      await dispatchKey(conn, keyName, modBits);
      emit('action', { action: 'press', combo });
    },

    async pressTarget(targetId, combo) {
      const conn = await getConn(targetId);
      const { keyName, modBits } = parseCombo(combo);
      await dispatchKey(conn, keyName, modBits);
      emit('action', { action: 'press', target: targetId, combo });
    },

    // ── Fill ─────────────────────────────────────────────────────

    async fill(selector, text) {
      const conn = await getConn();
      const rect = await getElementRect(conn, selector);
      const x = Math.round(rect.x + rect.width / 2);
      const y = Math.round(rect.y + rect.height / 2);
      await dispatchClick(conn, x, y);
      await dispatchKey(conn, 'a', MODIFIERS.Meta);
      await dispatchKey(conn, 'Backspace');
      await typeText(conn, text);
      emit('action', { action: 'fill', selector, text });
    },

    async fillTarget(targetId, selector, text) {
      const conn = await getConn(targetId);
      const rect = await getElementRect(conn, selector);
      const x = Math.round(rect.x + rect.width / 2);
      const y = Math.round(rect.y + rect.height / 2);
      await dispatchClick(conn, x, y);
      await dispatchKey(conn, 'a', MODIFIERS.Meta);
      await dispatchKey(conn, 'Backspace');
      await typeText(conn, text);
      emit('action', { action: 'fill', target: targetId, selector, text });
    },

    // ── Wait / Assert ───────────────────────────────────────────

    async waitFor(selector, timeoutSecs = 10) {
      const timeout = timeoutSecs * 1000;
      const conn = await getConn();
      const start = Date.now();
      while (Date.now() - start < timeout) {
        try {
          await getElementRect(conn, selector);
          emit('action', { action: 'waitFor', selector, found: true });
          return;
        } catch {}
        await new Promise(r => setTimeout(r, 200));
      }
      throw new Error(`Timed out waiting for "${selector}" after ${timeoutSecs}s`);
    },

    async waitForTarget(targetId, selector, timeoutSecs = 10) {
      const timeout = timeoutSecs * 1000;
      const conn = await getConn(targetId);
      const start = Date.now();
      while (Date.now() - start < timeout) {
        try {
          await getElementRect(conn, selector);
          emit('action', { action: 'waitFor', target: targetId, selector, found: true });
          return;
        } catch {}
        await new Promise(r => setTimeout(r, 200));
      }
      throw new Error(`Timed out waiting for "${selector}" in target ${targetId} after ${timeoutSecs}s`);
    },

    async assertVisible(selector) {
      const conn = await getConn();
      const rect = await getElementRect(conn, selector);
      emit('assert', { assertion: 'visible', selector, rect });
    },

    async assertText(selector, expected) {
      const conn = await getConn();
      const text = await evalInTarget(conn, `(() => {
        ${DEEP_QUERY_FN}
        const el = deepQuery(${JSON.stringify(selector)});
        if (!el) return null;
        return el.textContent.trim();
      })()`);
      if (text === null) throw new Error(`Element "${selector}" not found`);
      if (!text.includes(expected)) {
        throw new Error(`Text mismatch: "${selector}" has "${text}", expected to contain "${expected}"`);
      }
      emit('assert', { assertion: 'text', selector, expected, actual: text });
    },

    async assertGone(selector) {
      const conn = await getConn();
      const gone = await evalInTarget(conn, `(() => {
        ${DEEP_QUERY_FN}
        return deepQuery(${JSON.stringify(selector)}) === null;
      })()`);
      if (!gone) throw new Error(`Element "${selector}" still present in DOM`);
      emit('assert', { assertion: 'gone', selector });
    },

    // ── Screenshot ──────────────────────────────────────────────

    async screenshot(path) {
      const outPath = path || '/tmp/agentwfy-screenshot.png';
      const conn = await getConn();
      const { data } = await conn.send('Page.captureScreenshot', { format: 'png' });
      writeFileSync(outPath, Buffer.from(data, 'base64'));
      emit('action', { action: 'screenshot', path: outPath });
      return outPath;
    },

    async screenshotTarget(targetId, path) {
      const outPath = path || '/tmp/agentwfy-screenshot.png';
      const conn = await getConn(targetId);
      const { data } = await conn.send('Page.captureScreenshot', { format: 'png' });
      writeFileSync(outPath, Buffer.from(data, 'base64'));
      emit('action', { action: 'screenshot', target: targetId, path: outPath });
      return outPath;
    },

    // ── DOM Queries ─────────────────────────────────────────────

    async getRect(selector) {
      const conn = await getConn();
      return getElementRect(conn, selector);
    },

    async getText(selector) {
      const conn = await getConn();
      const text = await evalInTarget(conn, `(() => {
        ${DEEP_QUERY_FN}
        const el = deepQuery(${JSON.stringify(selector)});
        if (!el) return null;
        return el.textContent.trim();
      })()`);
      if (text === null) throw new Error(`Element "${selector}" not found`);
      return text;
    },

    async getHTML(selector) {
      const conn = await getConn();
      const html = await evalInTarget(conn, `(() => {
        ${DEEP_QUERY_FN}
        const el = deepQuery(${JSON.stringify(selector)});
        if (!el) return null;
        return el.innerHTML;
      })()`);
      if (html === null) throw new Error(`Element "${selector}" not found`);
      return html;
    },

    // ── Utility ─────────────────────────────────────────────────

    async sleep(ms) {
      await new Promise(r => setTimeout(r, ms));
    },

    log(label, data) {
      emit('log', { label, data });
    },

    async logs(n = 50) {
      const logPath = join(dirname(fileURLToPath(import.meta.url)), '..', '.dev.log');
      try {
        const content = readFileSync(logPath, 'utf-8');
        const lines = content.split('\n');
        return lines.slice(-n).join('\n').trim();
      } catch {
        return null;
      }
    },
  };

  // Execute script
  const fnNames = Object.keys(api);
  const fnValues = fnNames.map(n => api[n]);

  // Wrap script in async function with API destructured into scope
  const wrappedScript = `return (async (${fnNames.join(', ')}) => {\n${script}\n})(${fnNames.map((_, i) => `args[${i}]`).join(', ')});`;

  let result;
  try {
    const fn = new Function('args', wrappedScript);
    result = await fn(fnValues);
  } catch (e) {
    emit('error', { message: e.message, stack: e.stack });
    closeAll();
    process.exit(1);
  }

  if (result !== undefined) {
    emit('result', { data: result });
  }

  closeAll();
}

// ── Main ──────────────────────────────────────────────────────────────────

const [cmd, ...args] = process.argv.slice(2);

const commands = {
  start: () => cmdStart(args),
  stop: () => cmdStop(),
  restart: () => cmdRestart(),
  run: () => cmdRun(args.join(' ')),
};

if (!cmd || !commands[cmd]) {
  console.log('Usage: ./scripts/cdp <command> [args...]');
  console.log('');
  console.log('Commands:');
  console.log('  start [--visible]      Start isolated test instance (headless by default)');
  console.log('  stop                   Stop app and clean up test data');
  console.log('  restart                Restart app and wait until ready');
  console.log('  run <script-or-file>   Execute a JS test script with the full API');
  process.exit(1);
}

commands[cmd]().then(() => {
  process.exit(0);
}).catch(e => {
  console.error(`Error: ${e.message}`);
  process.exit(1);
});
