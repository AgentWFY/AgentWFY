#!/usr/bin/env node
// Launch a browser-accessible preview of the app from any worktree.
// Source is mounted into the container — code changes are picked up on app reload.
//
// Usage:
//   ./scripts/preview                                  Current directory
//   ./scripts/preview <worktree-path>                  Specific worktree
//   ./scripts/preview <worktree> --agent <agent-path>  With existing agent data
//   ./scripts/preview --restart <name>                 Rebuild and restart app
//   ./scripts/preview --stop [name]                    Stop a preview (or all)
//   ./scripts/preview --list                           List running previews
//   ./scripts/preview --cdp <name>                     Print CDP base URL and /json
//   ./scripts/preview --screenshot <name> [--no-settle] <path>  Composited screenshot (grim; default 500ms settle)
//   ./scripts/preview --record-start <name>                    Start wf-recorder (mp4 in container)
//   ./scripts/preview --record-stop <name> <path>              Stop recorder, copy mp4 to <path>
//   ./scripts/preview --sqlite <name> <sql>            Run SQL against the agent DB
//   ./scripts/preview --eval <name> [--tab <frag>] <expr>   CDP Runtime.evaluate
//   ./scripts/preview --logs <name> [--renderer] [-n N]  Main/renderer logs (stream, or last N)
//   ./scripts/preview --inspect tabs <name>           Main-process tab state dump
//   ./scripts/preview --exec <name> <cmd...>           docker exec passthrough

import { execSync, spawnSync } from 'node:child_process';
import { dirname, join, resolve, basename } from 'node:path';
import { fileURLToPath } from 'node:url';
import { existsSync, writeFileSync, unlinkSync } from 'node:fs';
import { createServer } from 'node:net';
import { setTimeout as sleep } from 'node:timers/promises';

async function waitForCdpReady(port, timeoutMs = 120_000) {
  const start = Date.now();
  while (Date.now() - start < timeoutMs) {
    try {
      const res = await fetch(`http://localhost:${port}/json`, { signal: AbortSignal.timeout(2000) });
      if (res.ok) {
        const list = await res.json();
        if (Array.isArray(list) && list.some((t) => t.type === 'page' && typeof t.url === 'string' && t.url.startsWith('app://'))) {
          return;
        }
      }
    } catch {}
    await sleep(500);
  }
  throw new Error(`CDP readiness timed out on :${port} (no app:// target).`);
}

const scriptDir = dirname(fileURLToPath(import.meta.url));
const defaultRoot = join(scriptDir, '..');
const PREFIX = 'agentwfy-preview';
const IMAGE = 'agentwfy-preview-base';

const args = process.argv.slice(2);

function containerFor(name) { return `${PREFIX}-${name}`; }

// Returns host port mapped to a given container port for a container, or null.
function mappedHostPort(container, containerPort) {
  try {
    const out = execSync(`docker port ${container} ${containerPort}/tcp`, { encoding: 'utf-8' }).trim();
    if (!out) return null;
    // docker port output: "0.0.0.0:54321" (possibly multiple lines — take first)
    const m = out.split('\n')[0].match(/:(\d+)$/);
    return m ? Number(m[1]) : null;
  } catch { return null; }
}

function requireName(flag) {
  const name = args[1];
  if (!name) { console.error(`Usage: ./scripts/preview ${flag} <name> [...]`); process.exit(1); }
  const container = containerFor(name);
  try { execSync(`docker inspect ${container}`, { stdio: 'pipe' }); }
  catch { console.error(`No preview named "${name}". Use --list.`); process.exit(1); }
  warnIfStale(container, name);
  return { name, container };
}

// Warn when the container's image ID doesn't match the current base
// image — which happens when scripts/ or Dockerfile have been updated
// since the container was started. Previews built before a change will
// silently lack new /cdp-eval, /cdp-logs, Chromium flags, etc. and
// subcommands fail in ways that look like broken docs.
function warnIfStale(container, name) {
  try {
    const containerImage = execSync(`docker inspect ${container} --format '{{.Image}}'`, { encoding: 'utf-8' }).trim();
    const currentImage = execSync(`docker image inspect ${IMAGE} --format '{{.Id}}'`, { encoding: 'utf-8' }).trim();
    if (containerImage && currentImage && containerImage !== currentImage) {
      console.error(`[preview] WARNING: preview "${name}" is running an older image than ${IMAGE}.`);
      console.error(`[preview] Stop it and re-run ./scripts/preview to pick up the latest fixes:`);
      console.error(`[preview]   ./scripts/preview --stop ${name} && ./scripts/preview`);
    }
  } catch {
    // If either image has been pruned, skip the check rather than noise.
  }
}

if (args[0] === '--list') {
  try {
    execSync(`docker ps --filter "name=${PREFIX}" --format "table {{.Names}}\t{{.Ports}}\t{{.Status}}"`, { stdio: 'inherit' });
  } catch { console.log('No previews running.'); }
  process.exit(0);
}

if (args[0] === '--stop') {
  const name = args[1];
  if (name) {
    const container = containerFor(name);
    try { execSync(`docker stop ${container} && docker rm ${container}`, { stdio: 'inherit' }); }
    catch { console.log(`No preview named "${name}".`); }
  } else {
    try {
      const ids = execSync(`docker ps -q --filter "name=${PREFIX}"`, { encoding: 'utf-8' }).trim();
      if (ids) {
        execSync(`docker stop ${ids.split('\n').join(' ')}`, { stdio: 'inherit' });
        execSync(`docker rm ${ids.split('\n').join(' ')}`, { stdio: 'pipe' });
      } else {
        console.log('No previews running.');
      }
    } catch {}
  }
  process.exit(0);
}

if (args[0] === '--restart') {
  const { name, container } = requireName('--restart');
  try {
    execSync(`docker exec ${container} bash -c 'kill $(pgrep -f "electron /app" | head -1)'`, { stdio: 'pipe' });
    process.stdout.write(`Restarting app in ${name}... `);
  } catch {
    console.log(`App not running in ${name}.`);
    process.exit(0);
  }
  const cdpPort = mappedHostPort(container, 9224);
  if (!cdpPort) {
    console.log('(CDP port not published; skipping readiness wait.)');
    process.exit(0);
  }
  try {
    await waitForCdpReady(cdpPort, 120_000);
    console.log('ready.');
  } catch (err) {
    console.log('timeout.');
    console.error(err.message);
    process.exit(1);
  }
  process.exit(0);
}

if (args[0] === '--logs') {
  const { container } = requireName('--logs');
  const renderer = args.includes('--renderer');
  const nFlagIdx = args.indexOf('-n');
  const nLines = nFlagIdx >= 0 && args[nFlagIdx + 1] ? parseInt(args[nFlagIdx + 1], 10) : null;
  if (renderer) {
    // Stream Runtime.consoleAPICalled from the main renderer via the
    // baked-in /cdp-logs.mjs helper.
    console.error('[preview] streaming renderer console — Ctrl+C to stop');
    const r = spawnSync('docker', ['exec', container, 'node', '/cdp-logs.mjs'], { stdio: 'inherit' });
    process.exit(r.status ?? 1);
  }
  if (nLines && Number.isFinite(nLines)) {
    // Snapshot the last N lines and exit — useful for one-shot checks.
    const r = spawnSync('docker', ['exec', container, 'tail', '-n', String(nLines), '/app/.dev.log'], { stdio: 'inherit' });
    process.exit(r.status ?? 1);
  }
  console.error('[preview] streaming /app/.dev.log — Ctrl+C to stop (use -n N for a snapshot)');
  const r = spawnSync('docker', ['exec', container, 'tail', '-F', '/app/.dev.log'], { stdio: 'inherit' });
  process.exit(r.status ?? 1);
}

if (args[0] === '--inspect') {
  const subject = args[1];
  const name = args[2];
  if (subject !== 'tabs' || !name) {
    console.error('Usage: ./scripts/preview --inspect tabs <name>');
    process.exit(1);
  }
  const container = containerFor(name);
  try { execSync(`docker inspect ${container}`, { stdio: 'pipe' }); }
  catch { console.error(`No preview named "${name}". Use --list.`); process.exit(1); }
  const r = spawnSync('docker', ['exec', container, 'node', '/cdp-eval.mjs',
    'await window.ipc.tabs.describe()'], { stdio: 'inherit' });
  process.exit(r.status ?? 1);
}

if (args[0] === '--cdp') {
  const { container } = requireName('--cdp');
  const port = mappedHostPort(container, 9224);
  if (!port) { console.error('CDP port 9223 is not published. Rebuild the preview.'); process.exit(1); }
  console.log(`  base: http://localhost:${port}`);
  console.log(`  list: http://localhost:${port}/json`);
  process.exit(0);
}

if (args[0] === '--screenshot') {
  const { container } = requireName('--screenshot');
  const rest = args.slice(2);
  const noSettleIdx = rest.indexOf('--no-settle');
  const noSettle = noSettleIdx !== -1;
  if (noSettle) rest.splice(noSettleIdx, 1);
  const outPath = rest[0] ? resolve(rest[0]) : join(process.cwd(), 'preview-screenshot.png');
  try {
    // Default settle lets tab switches / bounds changes land before grim samples —
    // selectTab + updateViewBounds is async through the renderer → main round-trip.
    // Use --no-settle to capture mid-transition state for race-condition repros
    // (see docs/TESTING.md "Catching transient state").
    const settle = noSettle ? '' : 'sleep 0.5 && ';
    execSync(`docker exec ${container} bash -lc 'export XDG_RUNTIME_DIR=/tmp/preview-xdg; export WAYLAND_DISPLAY=$(basename $(ls /tmp/preview-xdg/wayland-* 2>/dev/null | grep -v lock | head -1)); ${settle}grim /tmp/preview-screenshot.png'`, { stdio: 'pipe' });
    execSync(`docker cp ${container}:/tmp/preview-screenshot.png "${outPath}"`, { stdio: 'pipe' });
    console.log(outPath);
  } catch (err) {
    console.error(`Screenshot failed: ${err.message}`);
    process.exit(1);
  }
  process.exit(0);
}

if (args[0] === '--record-start') {
  const { container } = requireName('--record-start');
  try {
    // wf-recorder writes mp4 in the container; we SIGINT to finalize cleanly.
    // -y overwrites any leftover file from a previous aborted run.
    execSync(`docker exec -d ${container} bash -lc '
      export XDG_RUNTIME_DIR=/tmp/preview-xdg
      export WAYLAND_DISPLAY=$(basename $(ls /tmp/preview-xdg/wayland-* 2>/dev/null | grep -v lock | head -1))
      rm -f /tmp/preview-recording.mp4 /tmp/preview-recording.pid
      wf-recorder -y -o HEADLESS-1 -f /tmp/preview-recording.mp4 >/tmp/preview-recording.log 2>&1 &
      echo $! > /tmp/preview-recording.pid
    '`, { stdio: 'pipe' });
    // Give wf-recorder a moment to open the output and start capturing
    // before the caller fires the first UI action.
    await sleep(800);
    console.log(`Recording started in ${args[1]}.`);
  } catch (err) {
    console.error(`record-start failed: ${err.message}`);
    process.exit(1);
  }
  process.exit(0);
}

if (args[0] === '--record-stop') {
  const { container } = requireName('--record-stop');
  const outPath = args[2] ? resolve(args[2]) : join(process.cwd(), 'preview-recording.mp4');
  try {
    execSync(`docker exec ${container} bash -lc '
      PID=$(cat /tmp/preview-recording.pid 2>/dev/null || true)
      if [ -z "$PID" ] || ! kill -0 "$PID" 2>/dev/null; then
        echo "no active recording" >&2
        exit 1
      fi
      # SIGINT lets wf-recorder flush the MP4 moov atom. SIGTERM/SIGKILL
      # would leave an unplayable file.
      kill -INT "$PID"
      for i in $(seq 1 150); do
        kill -0 "$PID" 2>/dev/null || break
        sleep 0.1
      done
      if kill -0 "$PID" 2>/dev/null; then
        echo "wf-recorder did not exit; forcing" >&2
        kill -9 "$PID" 2>/dev/null || true
      fi
      rm -f /tmp/preview-recording.pid
    '`, { stdio: 'inherit' });
    execSync(`docker cp ${container}:/tmp/preview-recording.mp4 "${outPath}"`, { stdio: 'pipe' });
    console.log(outPath);
  } catch (err) {
    console.error(`record-stop failed: ${err.message}`);
    process.exit(1);
  }
  process.exit(0);
}

if (args[0] === '--sqlite') {
  const { container } = requireName('--sqlite');
  const sql = args.slice(2).join(' ');
  if (!sql) { console.error('Usage: ./scripts/preview --sqlite <name> "<sql>"'); process.exit(1); }
  // Pull AGENT_PATH from the running entrypoint (PID 1) so --agent mounts resolve correctly.
  const r = spawnSync('docker', ['exec', '-i', container, 'bash', '-lc',
    `AGENT_PATH=$(tr '\\0' '\\n' < /proc/1/environ | awk -F= '/^AGENT_PATH=/ {print $2}'); sqlite3 "${'$'}{AGENT_PATH:-/tmp/preview-agent}/.agentwfy/agent.db"`],
    { input: sql + '\n', stdio: ['pipe', 'inherit', 'inherit'] });
  process.exit(r.status ?? 1);
}

if (args[0] === '--eval') {
  const { container } = requireName('--eval');
  const rest = args.slice(2);
  let tabFrag = null;
  for (let i = 0; i < rest.length; i++) {
    if (rest[i] === '--tab' && rest[i + 1]) { tabFrag = rest[i + 1]; rest.splice(i, 2); i--; }
  }
  const expr = rest.join(' ').trim();
  if (!expr) {
    console.error('Usage: ./scripts/preview --eval <name> [--tab <url-fragment>] "<expression>"');
    process.exit(1);
  }
  const dockerArgs = ['exec', container, 'node', '/cdp-eval.mjs'];
  if (tabFrag) dockerArgs.push('--target', tabFrag);
  dockerArgs.push(expr);
  const r = spawnSync('docker', dockerArgs, { stdio: 'inherit' });
  process.exit(r.status ?? 1);
}

if (args[0] === '--exec') {
  const { container } = requireName('--exec');
  const rest = args.slice(2);
  if (!rest.length) { console.error('Usage: ./scripts/preview --exec <name> <cmd...>'); process.exit(1); }
  const r = spawnSync('docker', ['exec', container, ...rest], { stdio: 'inherit' });
  process.exit(r.status ?? 1);
}

// Parse args
let appPath = null;
let agentPath = null;

for (let i = 0; i < args.length; i++) {
  if (args[i] === '--agent' && args[i + 1]) {
    agentPath = resolve(args[i + 1]);
    i++;
  } else if (!args[i].startsWith('--')) {
    appPath = resolve(args[i]);
  }
}

appPath = appPath || defaultRoot;

if (!existsSync(join(appPath, 'scripts', 'start'))) {
  console.error(`Not an agentwfy directory: ${appPath}`);
  process.exit(1);
}

if (agentPath && !existsSync(join(agentPath, '.agentwfy', 'agent.db'))) {
  console.error(`Not an agent directory (no .agentwfy/agent.db): ${agentPath}`);
  process.exit(1);
}

const dirName = basename(appPath).replace(/[^a-z0-9-]/gi, '-').toLowerCase();
const containerName = containerFor(dirName);

function findFreePort() {
  return new Promise((resolve, reject) => {
    const srv = createServer();
    srv.listen(0, '127.0.0.1', () => {
      const port = srv.address().port;
      srv.close(() => resolve(port));
    });
    srv.on('error', reject);
  });
}

async function main() {
  const vncPort = await findFreePort();
  const cdpPort = await findFreePort();
  const dockerfile = join(scriptDir, 'Dockerfile.preview');

  try { execSync(`docker stop ${containerName} && docker rm ${containerName}`, { stdio: 'pipe' }); } catch {}

  // Build base image once (has all deps, Electron, tsgo cached)
  // Use any worktree just for the setup scripts — they're the same across worktrees
  console.log(`[preview] Building base image...`);
  const hadDockerignore = existsSync(join(appPath, '.dockerignore'));
  if (!hadDockerignore) {
    writeFileSync(join(appPath, '.dockerignore'), 'vendor/\ndist/\nnode_modules/\n.git/\ntests/\n');
  }
  try {
    execSync(`docker build -f "${dockerfile}" -t ${IMAGE} .`, {
      cwd: appPath,
      stdio: 'inherit',
    });
  } finally {
    if (!hadDockerignore) {
      try { unlinkSync(join(appPath, '.dockerignore')); } catch {}
    }
  }

  // Run with source mounted
  const dockerArgs = [
    'run', '-d',
    '--name', containerName,
    '--shm-size=256m',
    '-p', `${vncPort}:6080`,
    '-p', `${cdpPort}:9224`,
    '-v', `${appPath}:/src:ro`,
  ];

  if (agentPath) {
    dockerArgs.push('-v', `${agentPath}:/agent`);
    dockerArgs.push('-e', 'AGENT_PATH=/agent');
  }

  dockerArgs.push(IMAGE);

  console.log(`[preview] Starting ${containerName} (VNC ${vncPort}, CDP ${cdpPort})...`);
  if (agentPath) console.log(`[preview] Agent: ${agentPath}`);
  console.log(`[preview] Source: ${appPath} (mounted, changes picked up on reload)`);
  execSync(`docker ${dockerArgs.join(' ')}`, { stdio: 'inherit' });

  // Wait for CDP to serve an app:// target so the first scripted call
  // doesn't race the Electron boot (otherwise /json returns empty or the
  // connection is refused for a few seconds).
  process.stdout.write('[preview] Waiting for app to come up... ');
  try {
    await waitForCdpReady(cdpPort);
    console.log('ready.');
  } catch (err) {
    console.log('timeout.');
    console.error(err.message);
    process.exit(1);
  }

  const url = `http://localhost:${vncPort}/vnc.html?autoconnect=true&resize=scale&quality=9&compression=0`;
  console.log(`\n  VNC: ${url}`);
  console.log(`  CDP: http://localhost:${cdpPort}/json  (e.g. curl ... | jq)\n`);
  console.log(`  Restart:    ./scripts/preview --restart ${dirName}`);
  console.log(`  Stop:       ./scripts/preview --stop ${dirName}`);
  console.log(`  Screenshot: ./scripts/preview --screenshot ${dirName} out.png`);
  console.log(`  SQL:        ./scripts/preview --sqlite ${dirName} "SELECT name FROM views"`);
  console.log(`  Eval:       ./scripts/preview --eval ${dirName} "await window.ipc.tabs.getTabState()"`);
  console.log(`  List:       ./scripts/preview --list\n`);
}

main().catch(err => { console.error(err.message); process.exit(1); });
