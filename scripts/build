#!/usr/bin/env node
import { execSync } from 'child_process'
import { cpSync, mkdirSync, readdirSync, readFileSync, rmSync, writeFileSync } from 'fs'
import { dirname, join } from 'path'
import { fileURLToPath } from 'url'
import { ensureVendor } from './lib/ensure-vendor.mjs'

const __dirname = dirname(fileURLToPath(import.meta.url))
const root = join(__dirname, '..')

ensureVendor(root)
const src = join(root, 'src')
const dist = join(root, 'dist')

rmSync(dist, { recursive: true, force: true })

// ── Static assets ──

mkdirSync(join(dist, 'renderer'), { recursive: true })
cpSync(join(src, 'renderer', 'index.html'), join(dist, 'renderer', 'index.html'))
cpSync(join(src, 'renderer', 'global.css'), join(dist, 'renderer', 'global.css'))
cpSync(join(src, 'command_palette.html'), join(dist, 'command_palette.html'))
cpSync(join(src, 'confirmation.html'), join(dist, 'confirmation.html'))
cpSync(join(root, 'icons', 'icon.png'), join(dist, 'icon.png'))

// ── System data ──

// Docs
const docsDir = join(src, 'system-docs')
const docFiles = readdirSync(docsDir).filter(f => f.endsWith('.md')).sort()
const docs = docFiles.map(f => ({ name: f.replace(/\.md$/, ''), content: readFileSync(join(docsDir, f), 'utf-8') }))
writeFileSync(join(dist, 'system-docs.json'), JSON.stringify(docs))

// Views
const viewsDir = join(src, 'system-views')
const viewFiles = readdirSync(viewsDir).filter(f => f.endsWith('.html')).sort()
const views = viewFiles.map(f => {
  const content = readFileSync(join(viewsDir, f), 'utf-8')
  const name = f.replace(/\.html$/, '')
  const titleMatch = content.match(/<title>([^<]+)<\/title>/i)
  const title = titleMatch ? titleMatch[1].trim() : name.split('.').pop().charAt(0).toUpperCase() + name.split('.').pop().slice(1)
  return { name, title, content }
})
writeFileSync(join(dist, 'system-views.json'), JSON.stringify(views))

// Config
const configData = readFileSync(join(src, 'system-config', 'system-config.json'), 'utf-8')
const configItems = JSON.parse(configData)
writeFileSync(join(dist, 'system-config.json'), JSON.stringify(configItems))

// ── TypeScript compilation ──

const tsgo = join(root, 'vendor', 'tsgo', 'lib', process.platform === 'win32' ? 'tsgo.exe' : 'tsgo')
execSync(`"${tsgo}"`, { cwd: root, stdio: 'inherit' })

// ── Preload bundling ──
// Electron's sandboxed preload can only require() built-in modules.
// Inline local requires so the preload is self-contained.

const preloadPath = join(dist, 'preload.cjs')
let preloadCode = readFileSync(preloadPath, 'utf-8')

// Inline channels.cjs — read its Channels export and replace the require call
const channelsCode = readFileSync(join(dist, 'ipc', 'channels.cjs'), 'utf-8')
const channelsMatch = channelsCode.match(/exports\.Channels\s*=\s*(\{[\s\S]*?\});/)
if (!channelsMatch) throw new Error('Failed to extract Channels from dist/ipc/channels.cjs')
const requirePattern = /const channels_cjs_1 = require\("\.\/ipc\/channels\.cjs"\);/
if (!requirePattern.test(preloadCode)) throw new Error('Preload channels require() not found — compiler output may have changed')
preloadCode = preloadCode.replace(
  requirePattern,
  `const channels_cjs_1 = { Channels: ${channelsMatch[1]} };`,
)
writeFileSync(preloadPath, preloadCode)
