#!/usr/bin/env node
import { spawn, spawnSync } from 'child_process'
import { randomBytes } from 'crypto'
import { dirname, join } from 'path'
import { fileURLToPath } from 'url'
import { ensureVendor } from './lib/ensure-vendor.mjs'

const __dirname = dirname(fileURLToPath(import.meta.url))
const root = join(__dirname, '..')

ensureVendor(root)

if (!process.env.AGENTWFY_APP_ID && process.env.AGENTWFY_HEADLESS) {
  // Headless: always isolate with a unique app ID so parallel test runs don't collide.
  process.env.AGENTWFY_APP_ID = `AgentWFY-test-${randomBytes(4).toString('hex')}`
}

const electronDir = join(root, 'vendor', 'electron')

const binaryPath = process.platform === 'darwin'
  ? join(electronDir, 'Electron.app', 'Contents', 'MacOS', 'Electron')
  : process.platform === 'win32'
    ? join(electronDir, 'electron.exe')
    : join(electronDir, 'electron')

function resetTerminal() {
  try { spawnSync('stty', ['sane'], { stdio: 'ignore' }) } catch {}
}

process.on('SIGINT', () => { resetTerminal(); process.exit(130) })
process.on('SIGTERM', () => { resetTerminal(); process.exit(143) })

const cdpPort = process.env.CDP_PORT

function launchElectron() {
  const extraArgs = cdpPort ? [`--remote-debugging-port=${cdpPort}`] : []
  const child = spawn(binaryPath, [root, ...extraArgs, ...process.argv.slice(2)], {
    stdio: ['ignore', 'inherit', 'inherit'],
    env: { ...process.env, NODE_OPTIONS: '--disable-warning=ExperimentalWarning' },
  })

  child.on('exit', (code, signal) => {
    if (!signal && code === 100) {
      launchElectron()
      return
    }
    process.exit(code ?? 0)
  })
}

launchElectron()
