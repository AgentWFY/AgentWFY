{
  "name": "agentwfy-app",
  "productName": "AgentWFY",
  "version": "1.0.0",
  "description": "AI agent desktop app with local SQLite database",
  "type": "module",
  "main": "dist/main.js",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "clean-dist": "rm -rf dist",
    "copy-main-assets": "find src -maxdepth 1 \\( -name '*.html' -o -name '*.css' \\) -exec cp {} dist/ \\;",
    "build-main": "tsc --build && npm run copy-main-assets",
    "build-renderer": "cd src/renderer && npx vite build",
    "build": "npm run clean-dist && npm run build-main && npm run build-renderer",
    "start": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' electron .",
    "dev-renderer": "cd src/renderer && npx vite",
    "dev": "bash scripts/dev.sh",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "electron": "npm:electron-nightly@^41.0.0-nightly.20251219",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "keywords": [],
  "author": {
    "name": "endenwer",
    "email": "endenwer@gmail.com"
  },
  "license": "MIT"
}
