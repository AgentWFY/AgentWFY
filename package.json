{
  "name": "agentwfy-app",
  "productName": "AgentWFY",
  "version": "1.0.0",
  "description": "AI agent desktop app with local SQLite database",
  "type": "module",
  "main": "dist/main.js",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "build": "rm -rf dist && node scripts/build.mjs",
    "start": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' electron .",
    "dev": "bash scripts/dev.sh",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "electron": "npm:electron-nightly@^41.0.0-nightly.20251219",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3"
  },
  "keywords": [],
  "author": {
    "name": "endenwer",
    "email": "endenwer@gmail.com"
  },
  "license": "MIT"
}
